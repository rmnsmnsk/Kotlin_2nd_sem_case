@startuml

class Game {
    - id: Int
    - rules: Ruleset
    - board: Board
    - players: List<Player>
    - currentPlayer: Player
    + winner: Player
    + blackScore: Int
    + whiteScore: Int
    + nextPlayer()
    + makeMove(playerNumber: Int, x: Int, y: Int): Result
}

interface Ruleset {
    + createBoard(): Board
    + isValidMove(board: Board, x: Int, y: Int, playerColor: Int): Boolean
    + applyMove(board: Board, x: Int, y: Int, playerColor: Int): Board
    + isGameOver(board: Board): Boolean
    + getWinner(board: Board): Int
}

class ClassicRules {
    + createBoard(): Board
}

class AntiReversiRules extends ClassicRules {
    + getWinner(board: Board): Int
}

class Board {
    - cells: List<List<Cell>>
    + get(x: Int, y: Int): Cell
    + set(x: Int, y: Int, cell: Cell): Board
    + count(playerColor: Int): Int
    + isFull(): Boolean
}

class Cell {
    - value: CellValue
    - playerId: Int?
    + isEmpty(): Boolean
    + belongsTo(playerId: Int): Boolean
}

enum CellValue {
    EMPTY = 0
    BLACK = 1
    WHITE = 2
}

enum Result {
    VALID
    INVALID
    GAME_OVER
}

class Player {
    - id: Int
    - name: String
    - color: Int
    + getColor(): Int
    + getCellValue(): CellValue
}

interface BoardRenderer {
    + render(board: Board)
}

class ConsoleBoardRenderer {
    + render(board: Board)
}

interface PlayerRepository {
    + save(player: Player)
    + findById(id: Int): Player
    + findAll(): List<Player>
}

interface MatchRepository {
    + save(gameRecord: GameRecord)
    + findAll(): List<GameRecord>
}

class GameRecord {
    + id: Int
    + players: List<Int>
    + winnerId: Int?
    + moves: String
    + blackScore: Int
    + whiteScore: Int
    + date: String
}

' Отношения
Ruleset <|.. ClassicRules : implements
Ruleset <|-- AntiReversiRules : extends

Game *-- Ruleset : contains rules
Game *-- Board : owns board
Game *-- Player : owns players

Ruleset --> Board : validates and modifies
Board *-- Cell : composed of cells
Cell ..> CellValue : uses
Cell ..> Player : references
Player ..> CellValue : maps to

Result <.. Game : returns
Game --> BoardRenderer : renders via
BoardRenderer <|.. ConsoleBoardRenderer : implements
BoardRenderer --> Board : reads

Game --> PlayerRepository : stores statistics
Game --> MatchRepository : saves history
Game ..> GameRecord : creates

MatchRepository --> GameRecord : manages
PlayerRepository --> Player : manages

@enduml